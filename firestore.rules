rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /appointments/{id} {
      // Leitura pública: necessária para exibir horários ocupados no calendário
      allow read: if true;

      // Criação bloqueada no cliente: agendamentos só podem ser criados via
      // Cloud Function createAppointment (Admin SDK bypassa estas regras).
      // Isso impede que alguém crie agendamentos falsos via Postman ou console.
      allow create: if false;

      // Atualização e exclusão: apenas administradores autenticados via Firebase Auth
      allow update, delete: if request.auth != null;
    }

    match /visitors/{id} {
      // Escrita pública controlada: apenas insert de campos esperados (sem leitura)
      allow create: if request.resource.data.page is string
                    && request.resource.data.userAgent is string
                    && request.resource.data.accessedAt != null;

      // Leitura e exclusão: apenas admin autenticado
      allow read, delete: if request.auth != null;

      // Ninguém atualiza registros de visita
      allow update: if false;
    }

    // Rate limiting: Controle de spam por e-mail.
    // A Cloud Function createAppointment escreve aqui via Admin SDK.
    // Leitura bloqueada para o público (dados internos de controle).
    match /rateLimits/{emailKey} {
      allow read, write: if false;
    }

  }
}
